# Normalize line endings
* text=auto

# Dart/Flutter source files
*.dart text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.py text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
*.mp3 binary
*.mp4 binary
*.apk binary
*.aab binary
*.db binary
*.jar binary
*.keystore binary
